{
  "manifest_version": 3,
  "name": "A Quiosco",
  "version": "1.0",
  "description": "Añade el artículo abierto a tu revista de Quiosco (requiere Quiosco arrancado en localhost:4321)",
  "action": {
    "default_title": "Añadir este artículo a Quiosco",
    "default_icon": {
      "16": "icons/q16.png",
      "32": "icons/q32.png",
      "48": "icons/q48.png",
      "128": "icons/q128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/q16.png",
    "32": "icons/q32.png",
    "48": "icons/q48.png",
    "128": "icons/q128.png"
  },
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:4321/*"]
}
